<Window x:Class="pr2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Інтерактивний атлас м'язової системи" 
        Height="650" Width="1000" MinHeight="500" MinWidth="800">

    <Grid Background="{DynamicResource AppBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource MenuBgBrush}" Padding="15,10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💪" FontSize="24" Margin="0,0,10,0"
                               Foreground="{DynamicResource HeaderTitleBrush}"/>
                    <TextBlock Text="М'язова Система" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTitleBrush}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Головна" Style="{StaticResource MenuButton}" Click="NavHome_Click"/>
                    <Button Content="Список М'язів" Style="{StaticResource MenuButton}" Click="NavList_Click"/>
                    <Button Content="Налаштування" Style="{StaticResource MenuButton}" Click="NavSettings_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" />

        <StatusBar Grid.Row="2" Background="{DynamicResource StatusBarBgBrush}" Padding="10,5" BorderThickness="0,1,0,0" BorderBrush="#333333">
            <TextBlock Text="Головне меню завантажено" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
            <Separator Background="{DynamicResource TextMutedBrush}" Margin="5,0"/>
            <TextBlock Text="Масштаб: 100%" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
        </StatusBar>
    </Grid>
</Window>