<Page x:Class="pr2.Views.ListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ListPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Список м'язів" Style="{DynamicResource HeaderTextStyle}"/>
            <TextBox x:Name="SearchBox" Tag="Пошук м'яза..." Margin="0,0,0,15"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Muscles}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource PrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LatinName}" FontStyle="Italic" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>