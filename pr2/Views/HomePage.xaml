<Page x:Class="pr2.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage">

    <Grid Margin="20" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Каталог м'язів" Style="{DynamicResource HeaderTextStyle}"/>
            <TextBlock Text="Оберіть групу м'язів для детального вивчення" 
                       Foreground="{DynamicResource TextMutedBrush}" 
                       Margin="0,-10,0,20"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
            <WrapPanel Margin="-10">
                <Border Background="{DynamicResource CardBgBrush}" 
                        BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1"
                        Width="220" Height="150" Margin="10" Padding="15" CornerRadius="8">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="М'язи голови та шиї" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Мімічні, жувальні, поверхневі та глибокі м'язи шиї." 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBgBrush}" 
                        BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1"
                        Width="220" Height="150" Margin="10" Padding="15" CornerRadius="8">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="М'язи тулуба" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Грудні м'язи, м'язи живота (прес) та м'язи спини." 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBgBrush}" 
                        BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1"
                        Width="220" Height="150" Margin="10" Padding="15" CornerRadius="8">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Верхні кінцівки" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Дельтоподібний, біцепс, трицепс, м'язи передпліччя." 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBgBrush}" 
                        BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1"
                        Width="220" Height="150" Margin="10" Padding="15" CornerRadius="8">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Нижні кінцівки" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="Сідничні м'язи, квадрицепс, литкові м'язи." 
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" 
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Page>