<Window x:Class="pr2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Інтерактивний атлас м'язової системи" Height="600" Width="900">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Головна" Padding="15,5" Margin="5,0" Click="NavHome_Click"/>
                <Button Content="Список" Padding="15,5" Margin="5,0" Click="NavList_Click"/>
                <Button Content="Налаштування" Padding="15,5" Margin="5,0" Click="NavSettings_Click"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
    </DockPanel>
</Window>